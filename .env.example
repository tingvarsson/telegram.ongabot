# Telegram bot API token
API_TOKEN=your_telegram_bot_token_here

# Telegram user IDs (comma-separated) allowed to run /authorize and /deauthorize
BOT_ADMINS=your_telegram_user_id

# Optional: Chat IDs (comma-separated) to authorize on startup — useful for bootstrapping existing groups
AUTHORIZED_CHAT_IDS=

# Optional: logging level (default: INFO)
LOG_LEVEL=INFO

# Optional: path to the pickle persistence database (default: ongabot.db)
DB_PATH=ongabot.db
